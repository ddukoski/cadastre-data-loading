{
  "name": "api",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "DOTENV_CONFIG_PATH=../.env tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "DOTENV_CONFIG_PATH=../.env tsx src/index.ts",
    "load:data": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts",
    "load:data:opstini": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=opstini",
    "load:data:naselen": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=naselen_mesta",
    "load:data:ulici": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=ulici",
    "load:data:ulici-cr": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=ulici_cr",
    "load:data:kukni": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=kukni_broevi",
    "load:data:stanovi": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=stanovi",
    "load:data:parceli": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=parceli",
    "load:data:parceli-delovi": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=parceli_delovi",
    "load:data:zgradi": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=zgradi",
    "load:data:objekti": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=objekti",
    "load:data:prijavi": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=prijavi",
    "load:data:log": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=log_aktivnosti",
    "load:data:korisnici": "DOTENV_CONFIG_PATH=../.env NODE_OPTIONS=--max-old-space-size=4096 tsx src/load-data.ts --table=korisnici",
    "load:all": "npm run load:data:opstini && npm run load:data:naselen && npm run load:data:ulici-cr && npm run load:data:ulici && npm run load:data:kukni && npm run load:data:stanovi && npm run load:data:parceli && npm run load:data:parceli-delovi && npm run load:data:zgradi && npm run load:data:objekti && npm run load:data:korisnici && npm run load:data:prijavi && npm run load:data:log",
    "db:generate": "DOTENV_CONFIG_PATH=../.env drizzle-kit generate",
    "db:migrate": "DOTENV_CONFIG_PATH=../.env drizzle-kit migrate",
    "db:studio": "DOTENV_CONFIG_PATH=../.env drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.5.8",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
